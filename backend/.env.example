# ============================================================================
# MRSys — Variáveis de Ambiente (template)
# ============================================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# Nunca commit o .env (já está no .gitignore).
#
# Hospedagem atual: Hostinger cPanel (frontend + backend no mesmo domínio)
# Domínio: celso.cloud
# ============================================================================

# Aplicação
APP_NAME="MRSys"
APP_ENV=production              # local | production
APP_DEBUG=false                 # true em local, false em produção
APP_URL=https://celso.cloud
APP_TIMEZONE="America/Sao_Paulo"

# Chave de criptografia (gerar com: openssl rand -hex 32)
APP_KEY=

# Banco de dados (MySQL)
# ATENÇÃO Hostinger: nome do banco e usuário são prefixados com o ID da conta.
# Ex: se seu ID é u123456789, crie banco "u123456789_mrsys" e user "u123456789_mrsys"
DB_HOST=localhost
DB_PORT=3306
DB_NAME=u000000000_mrsys       # substituir pelo nome real gerado no hPanel
DB_USER=u000000000_mrsys       # substituir pelo usuário real gerado no hPanel
DB_PASS=                        # senha definida ao criar o banco no hPanel
DB_CHARSET=utf8mb4

# Sessão — mesma origem (frontend e backend no mesmo domínio = Lax)
SESSION_LIFETIME=480            # minutos (8 horas)
SESSION_SECURE=true             # sempre true em HTTPS
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax            # Lax funciona pois tudo está no mesmo domínio

# CORS — mesma origem, não há requisição cross-origin
# Deixe a URL do próprio site para bloquear origens externas inesperadas
CORS_ALLOWED_ORIGINS=https://celso.cloud

# Login (segurança)
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Uploads
UPLOAD_MAX_SIZE_MB=10           # foto e documentos de funcionários
UPLOAD_ALLOWED_TYPES="jpg,jpeg,png,pdf,doc,docx,xls,xlsx"

# ============================================================================
# Integração Cora (transferências PIX da folha)
# ============================================================================
# Cada empresa tem credenciais separadas. Os Client IDs são públicos (estão em
# request bodies), mas os certificados são SENSÍVEIS — guardar fora do
# public_html com chmod 600.
#
# Em STAGE, usar https://matls-clients.stage.cora.com.br (mTLS) ou ajustar
# após confirmar com a doc da Cora.

CORA_BASE_URL=https://matls-clients.api.stage.cora.com.br
CORA_TOKEN_URL=https://matls-clients.api.stage.cora.com.br/token
# Para PRODUÇÃO trocar para: https://matls-clients.api.cora.com.br

# MR ASSESSORIA
CORA_MR_CLIENT_ID=int-7SzA99mhM1tsdeOlTKV1Cy
CORA_MR_CERT_PATH=/home/SEU-USUARIO/cora-certs/mr-assessoria/certificate.pem
CORA_MR_KEY_PATH=/home/SEU-USUARIO/cora-certs/mr-assessoria/private-key.key
CORA_MR_WEBHOOK_SECRET=                                # gerado ao cadastrar webhook no painel Cora

# UP VIGILÂNCIA
CORA_UP_CLIENT_ID=int-5hkgOAMyBeJxYJoKTJ1rRC
CORA_UP_CERT_PATH=/home/SEU-USUARIO/cora-certs/up-vigilancia/certificate.pem
CORA_UP_KEY_PATH=/home/SEU-USUARIO/cora-certs/up-vigilancia/private-key.key
CORA_UP_WEBHOOK_SECRET=                                # gerado ao cadastrar webhook no painel Cora

# E-mail (recuperação de senha — configurar quando domínio próprio estiver ativo)
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="MRSys - Grupo MR"

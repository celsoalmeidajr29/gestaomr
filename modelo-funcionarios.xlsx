<?php
/**
 * ============================================================================
 * MRSys — Gerador de Hash de Senha
 * ============================================================================
 *
 * Use este arquivo UMA ÚNICA VEZ, logo após importar o MRSys_database.sql.
 *
 * COMO USAR:
 *   1. Faça upload deste arquivo para a raiz do seu site (public_html/)
 *      via FTP ou pelo Gerenciador de Arquivos do cPanel.
 *   2. Acesse no navegador: https://seudominio.com.br/gerar_hash.php
 *   3. A página mostra um comando SQL pronto. Copie ele inteiro.
 *   4. Vá no phpMyAdmin → selecione o banco MRSys → aba SQL.
 *   5. Cole o comando e clique "Executar".
 *   6. PRONTO — agora você pode logar com seu e-mail e senha.
 *
 * IMPORTANTE — APAGUE ESTE ARQUIVO depois de usar.
 * Deixar ele acessível na web é risco de segurança.
 * ============================================================================
 */

// Configurações — ajuste o e-mail se mudar de usuário
$email_admin = 'celso.almeida@grupomr.seg.br';
$senha_padrao = 'jr4540504@A';

// Gera o hash bcrypt nativo do PHP — compatível com password_verify()
$hash = password_hash($senha_padrao, PASSWORD_BCRYPT, ['cost' => 10]);

// Verificação imediata: o hash gerado realmente bate com a senha?
$verificacao = password_verify($senha_padrao, $hash) ? 'OK' : 'FALHOU';

// Comando SQL pronto para colar
$sql = "UPDATE usuarios SET senha_hash = '{$hash}' WHERE email = '{$email_admin}';";

?><!DOCTYPE html>
